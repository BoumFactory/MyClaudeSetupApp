% ====================================================================
% SECTION TCBSET-REFONTE : Contenu de bfcours-env-tcb.sty (mode standalone)
%   Définit les helpers + styles tcbset + les 12 envs refondus :
%   Theoreme, Definition, Propriete, Demonstration, Methode, Activite,
%   Vocabulaire, Solution, RemarqueOld, OldExemple, OldNotation, OldAide.
% ====================================================================

% =====================================================================
% bfcours-env-tcb.sty
%   Refactorisation des environnements didactiques bfcours en
%   styles tcolorbox (tcbset) PIXEL-PERFECT.
%
%   Auteur  : Romain Deschamps (refonte 2026-2027)
%   Objectif: factoriser le code dupliqué (~1700 lignes -> ~450)
%             SANS modifier le rendu PDF. Les bugs originaux sont
%             reproduits volontairement (Solution bordure rem,
%             Theoreme banderolle red direct, etc.).
%
%   Dépendances : tcolorbox, etoolbox, xparse, bclogo, bfcours-colors
%                 et l'environnement 'exo' (pour EXO/EXOEVAL).
% =====================================================================


% Option [override] : si fournie, on remplace les environnements déjà
% existants (cas où bfcours est chargé avant ce package). Sans l'option,
% on déclare les environnements normalement (cas standalone).


% Sélecteur de déclaration d'environnement : \NewDocumentEnvironment en
% mode standalone, \RenewDocumentEnvironment en mode override.
  \let\bfdDeclareEnv\NewDocumentEnvironment

% Idem pour \newtcolorbox / \renewtcolorbox
  \def\bfdDeclareTcb{\newtcolorbox}

% Idem pour \newcommand / \renewcommand (commandes hors préfixe \bfd...
% susceptibles de collisionner avec bfcours).
  \let\bfdDeclareCmd\newcommand

% =====================================================================
% Helper de déclaration d'environnement sémantique didactique.
%
% Tous les envs « Théorème / Définition / Propriété / Démonstration /
% Méthode / Activité / Vocabulaire / Solution / OldNotation / OldAide »
% suivent rigoureusement le même squelette :
%
%   1. Stocker le sous-titre (#1 utilisateur) dans \bfdSubTitle
%   2. Ouvrir une tcolorbox avec un style sémantique nommé
%   3. Appliquer un hook couleurs (qui colore tabular/items/accent texte)
%   4. Insérer le contenu utilisateur (#2 utilisateur)
%   5. Appeler le reset couleurs
%   6. Fermer la tcolorbox
%
% \bfdNewSemanticEnv prend :
%   #1 = nom de l'environnement LaTeX (ex. "Propriete")
%   #2 = nom du style tcbset (ex. "bfd propriete")
%   #3 = code à exécuter pour le hook couleurs (ex. \bfdSetColors{prop} ou
%        \bfdSetColorsTheoreme). Argument verbatim, donc on peut y mettre
%        des macros ou des arguments composés.
%
% Le reset utilise toujours \bfdResetColors (idempotent : sûr même si le
% hook utilisé n'a pas tout colorié, ex. \bfdSetColorsNoItem).
\NewDocumentCommand{\bfdNewSemanticEnv}{m m +m}{%
  \bfdDeclareEnv{#1}{O{} +b}{%
    \def\bfdSubTitle{##1}%
    \begin{tcolorbox}[#2]%
      #3%
      ##2%
      \bfdResetColors
    \end{tcolorbox}%
  }{}%
}

% bclogo doit être chargé par l'utilisateur (avec ses propres options) avant
% ce package, ou via bfcours.sty. On le requiert sans options pour ne pas
% provoquer d'option clash.
\@ifpackageloaded{bclogo}{}{\RequirePackage{bclogo}}

