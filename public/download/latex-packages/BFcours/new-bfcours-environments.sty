% --- MultiColonnes -------------------------------------------------
% Recopié à l'identique depuis bfcours-environments.sty (l. 1630-1678).
\bfdDeclareEnv{MultiColonnes}{m O{ColonnesBaseStyle}}{%
  % (3) si l'on N'EST PAS déjà dans un tcolorbox ⇒ on en ouvre un "vide"
  %\IfInsideTcolorboxTF
  %{
    \begin{tcolorbox}[blank,nobeforeafter,size=minimal, width=\textwidth,boxrule=0pt,left=0pt,right=0pt,top=0pt,bottom=0pt,halign=left,boxsep=0pt,
    colback            = \currentColContainerBackgroundColor,
    colframe           = \currentColContainerFrameColor]%
    %}%
  %{}% branche VRAIE (déjà dedans) : rien à faire
  % (4) le raster proprement dit
  \begin{tcbitemize}[%
    raster equal height=rows,
    nobeforeafter,
    boxsep=0pt,
    breakable,
    raster column skip = 5pt,
    raster row skip    = 2pt,
    raster columns     = #1,
    colback            = \currentBackgroundColor,
    colframe           = \currentFrameColor,
    boxrule            = 0pt,
    top                = 0pt,
    bottom             = 0pt,
    left               = 0pt,
    right              = 0pt,
    after skip         = 0pt,
    after upper        = {},
    after lower        = {},
    size=minimal,
    raster every box/.style={
      enhanced,
      breakable,
      size=small,
      halign=left,
      colback=\currentBackgroundColor,
      colframe=\currentFrameColor,
      coltitle=\currentTitleColor,
      fonttitle=\bfseries,
      #2
    }%
  ]%
  \ignorespaces
}{%
  \end{tcbitemize}%
  %\IfInsideTcolorboxTF{
  \end{tcolorbox}%
  %}{}%
  % Compense le \par implicite emis par la fermeture de la tcolorbox
  % conteneur ci-dessus : sans cela, ce \par ouvre un paragraphe vide
  % dans l'env englobant (Definition, Propriete, ...) qui produit un
  % "Underfull \hbox (badness 10000)" sur le \end{...} parent.
  % \nointerlineskip annule juste le saut de ligne automatique de ce
  % \par, sans inserer de hauteur visible.
  \par\nointerlineskip%
\ignorespacesafterend% gobe les blancs apres \end
}
% Commande pour mettre à jour le style de base
\bfdDeclareCmd{\setColonnesBaseStyle}[1]{%
  \tcbset{
    ColonnesBaseStyle/.style={
      #1
    }
  }%
}

% =====================================================================
% Section L3-L5 — Palette nommée + \bfset (Phase G architecture)
% =====================================================================
%
% L3 (palette) : table de correspondance nom-de-palette → mapping des
% couleurs sémantiques bfcours (thm, defi, prop, demo, meth, acti, voca,
% rem, nota, ex). Chaque palette redéfinit ces couleurs via \colorlet.
%
% L5 (\bfset)  : commande utilisateur unique pour activer une palette
% (et plus tard variant, shadow, etc.). Exemple :
%     \bfset{palette=ocean}
%     \bfset{palette=default}  % retour aux couleurs bfcours d'origine
%
% Backward compat : sans appel à \bfset, les couleurs bfcours-colors
% restent intactes (le mécanisme ne modifie rien à charge du package).
% =====================================================================

% Sauvegarder les couleurs bfcours-colors au boot pour permettre le
% retour à la palette "default" plus tard. Liste exacte des couleurs
% sémantiques bfcours : thm, defi, prop, demo, meth, act, rem, nota, ex.
% (Pas de `voca` — la voix Vocabulaire utilise `nota` dans bfcours.)
\AtBeginDocument{%
  \colorlet{bfd@default@thm}{thm}%
  \colorlet{bfd@default@defi}{defi}%
  \colorlet{bfd@default@prop}{prop}%
  \colorlet{bfd@default@demo}{demo}%
  \colorlet{bfd@default@meth}{meth}%
  \colorlet{bfd@default@act}{act}%
  \colorlet{bfd@default@rem}{rem}%
  \colorlet{bfd@default@nota}{nota}%
  \colorlet{bfd@default@ex}{ex}%
}

% Définir une palette : \NewBfdPalette{nom}{thm=blue, defi=teal, ...}
% Les valeurs sont des couleurs TikZ/xcolor (ex. "blue!70!cyan").
\NewDocumentCommand{\NewBfdPalette}{m m}{%
  \csdef{bfd@palette@#1}{#2}%
}

% Activer une palette : \bfdActivatePalette{ocean}.
% Émet un Warning silencieux si la palette n'existe pas.
% Note technique : on passe par \edef pour expanser le contenu de la
% csname AVANT que pgfqkeys ne le voie, sinon pgfqkeys reçoit le token
% de macro brut et traite tout comme une seule clé.
\NewDocumentCommand{\bfdActivatePalette}{m}{%
  \@ifundefined{bfd@palette@#1}{%
    \PackageWarning{bfcours-env-tcb}{Palette `#1' inconnue, ignorée}%
  }{%
    \edef\bfd@@palettekv{\noexpand\pgfqkeys{/bfd/palette}{\csname bfd@palette@#1\endcsname}}%
    \bfd@@palettekv
  }%
}

% Clés pgfkeys : chaque clé applique \colorlet{nom-bfcours}{valeur}.
\pgfkeys{
  /bfd/palette/.cd,
  thm/.code   = {\colorlet{thm}{#1}},
  defi/.code  = {\colorlet{defi}{#1}},
  prop/.code  = {\colorlet{prop}{#1}},
  demo/.code  = {\colorlet{demo}{#1}},
  meth/.code  = {\colorlet{meth}{#1}},
  act/.code   = {\colorlet{act}{#1}},
  rem/.code   = {\colorlet{rem}{#1}},
  nota/.code  = {\colorlet{nota}{#1}},
  ex/.code    = {\colorlet{ex}{#1}},
}

% PRINCIPE : une palette ne contient QUE des couleurs de base atomiques
% (nom xcolor pur, type "blue", "teal", "olive"…). Les nuances `!80!black`,
% `!50`, `!5` etc. utilisées dans les styles tcbset sont calculées
% dynamiquement par xcolor à partir de ces bases. Du coup, changer la
% palette ne demande qu'à redéfinir 9 couleurs ; tout le reste suit.
%
% Note pgfkeys : on définit les palettes en une seule ligne pour éviter
% que les sauts de ligne ne soient interprétés comme du texte.

% --------------------- Palette "default" ----------------------------
% Restaure les couleurs sauvegardées au boot du document (= les couleurs
% historiques de bfcours-colors).
\NewBfdPalette{default}{thm=bfd@default@thm,defi=bfd@default@defi,prop=bfd@default@prop,demo=bfd@default@demo,meth=bfd@default@meth,act=bfd@default@act,rem=bfd@default@rem,nota=bfd@default@nota,ex=bfd@default@ex}

% --------------------- Palette "ocean" ------------------------------
% Couleurs froides — bases atomiques uniquement (xcolor purs).
\NewBfdPalette{ocean}{thm=blue,defi=teal,prop=cyan,demo=purple,meth=blue,act=teal,rem=blue,nota=purple,ex=blue}

% --------------------- Palette "vintage" ----------------------------
% Couleurs chaudes — bases atomiques uniquement.
\NewBfdPalette{vintage}{thm=red,defi=olive,prop=orange,demo=brown,meth=brown,act=orange,rem=brown,nota=purple,ex=brown}

% --------------------- Variantes graphiques (L2) --------------------
% Trois variantes livrées (cf Section 3) : lignes (default), minimal, sidebar.
%
% Le mécanisme : on redéfinit dynamiquement la clé `bfd edge overlay`
% pour qu'elle pointe vers `bfd edge overlay <variant>`. Les styles
% `bfd theoreme`, `bfd definition`, etc. utilisent `bfd edge overlay`
% comme alias et suivent ainsi automatiquement la variante active.
\def\bfd@@set@variant#1{%
  \tcbset{bfd edge overlay/.style 2 args={bfd edge overlay #1={##1}{##2}}}%
}

% Au boot, on active la variante "lignes" (= comportement historique).
\bfd@@set@variant{lignes}

% Activer une autre variante : \bfdActivateVariant{minimal}.
% Émet un Warning si la variante n'existe pas (liste fermée).
\NewDocumentCommand{\bfdActivateVariant}{m}{%
  \def\bfd@@valid@variant{}%
  \@for\bfd@@v:={lignes,minimal,sidebar}\do{%
    \edef\bfd@@cmp{#1}%
    \ifx\bfd@@v\bfd@@cmp\def\bfd@@valid@variant{1}\fi
  }%
  \ifx\bfd@@valid@variant\@empty
    \PackageWarning{bfcours-env-tcb}{Variante `#1' inconnue, ignorée. Valides : lignes, minimal, sidebar}%
  \else
    \bfd@@set@variant{#1}%
  \fi
}

% --------------------- Interface \bfset (L5) ------------------------
% Commande utilisateur unique. Deux clés disponibles :
%   - palette=NAME (cf L3)
%   - variant=NAME (cf L2)
% Architecture extensible (shadow, accent, etc. à venir).
\pgfkeys{
  /bfd/.cd,
  palette/.code = {\bfdActivatePalette{#1}},
  variant/.code = {\bfdActivateVariant{#1}},
}

\NewDocumentCommand{\bfset}{m}{%
  \pgfqkeys{/bfd}{#1}%
}

% --------------------- Config externalisée (L6) ---------------------
% L'utilisateur (ou le futur logiciel) peut placer ses réglages dans
% un fichier externe et le charger via \bfLoadConfig{nom}. Le fichier
% est un .tex standard qui contient typiquement un appel à \bfset.
%
% Exemple de bfcours-config.tex :
%   \bfset{palette=ocean, variant=lignes}
%
% Le futur logiciel pourra générer/éditer ce fichier sans toucher au
% LaTeX : il suffit de réécrire la ligne \bfset{...}.
\NewDocumentCommand{\bfLoadConfig}{m}{%
  \IfFileExists{#1.tex}{%
    \input{#1.tex}%
  }{%
    \IfFileExists{#1}{%
      \input{#1}%
    }{%
      \PackageWarning{bfcours-env-tcb}{Fichier de config `#1' introuvable}%
    }%
  }%
}

% Au chargement du package, tenter automatiquement le fichier
% `bfcours-config.tex` du dossier courant (si présent). Permet à
% l'utilisateur d'activer une config par défaut sans \bfLoadConfig.
\AtBeginDocument{%
  \IfFileExists{bfcours-config.tex}{%
    \input{bfcours-config.tex}%
  }{}%
}

% =====================================================================
% Section 10 — Environnement « Histoire » (skin syBrisse / fancy-box)
% =====================================================================
% Boite d'histoire des mathematiques, au skin « banderolle pliee »
% (portage FIDELE du dessin TikZ \syBrisse de fancy-box.tex). Trois
% niveaux de texte :
%   * banderolle (onglet haut-droit) : libelle fixe « Un peu d'histoire »
%   * titre (haut-gauche, noir gras)  : le sujet,  ex. « La constante e »
%   * sous-sous-titre (ligne grise)   : l'auteur cite, ex. « L. Euler (1748) »
%
% Usage :
%   \begin{Histoire}{La constante e}[d'apres L. Euler, 1748]
%     ... contenu ...
%   \end{Histoire}
%   (le 2e argument — l'auteur — est OPTIONNEL : \begin{Histoire}{Titre} ...)
%
% Le style visuel est expose de facon reutilisable via
%   bfd syBrisse={<couleur>}{<LIBELLE ONGLET>}
% le titre et l'auteur etant lus dans \bfdSybTitle / \bfdSybAuthor.
% =====================================================================

% Couleur dediee : sepia/brun « vieux livre ».
\definecolor{histoire}{RGB}{120,72,48}

% Stockage des trois textes (poses par l'environnement avant la box).
\newcommand{\bfdSybTitle}{}
\newcommand{\bfdSybAuthor}{}

\tcbset{
  % -------------------------------------------------------------------
  % Skin « syBrisse » generique (portage du dessin TikZ d'origine).
  %   #1 = couleur semantique ;  #2 = libelle affiche dans l'onglet.
  % Le noeud (frame) de tcolorbox remplace le noeud (one) d'origine ;
  % un noeud de mesure (two) dimensionne l'onglet sur le libelle #2.
  % -------------------------------------------------------------------
  bfd syBrisse/.style 2 args={
    enhanced, breakable=false,
    colback=#1!6,
    colframe=#1, boxrule=0.8pt,
    arc=4pt, outer arc=4pt,
    top=23pt, bottom=3.5mm, left=4mm, right=4mm,
    before skip=3mm, after skip=3mm,
    % Bookkeeping TOC/hyperref hors titre (cf autres envs didactiques).
    code={\bfdLiencontentRegister{#2}{\bfdSybTitle}},
    % Sous-sous-titre (auteur) : 1re ligne grise du corps, auto-dimensionnee.
    before upper={\ifdefempty{\bfdSybAuthor}{}{%
        \noindent{\itshape\color{black!60}\small\bfdSybAuthor}\par\smallskip}},
    %===== DEGRADE BAS (sous le texte) : \path[top color=#3!5 ...] =====
    underlay={%
      \path[opacity=0.5, top color=#1!5, middle color=#1!30, bottom color=#1]
        ([xshift=0.9pt]interior.south west) [rounded corners=3pt] --
        ([xshift=-0.9pt]interior.south east) [sharp corners] --
        ([xshift=-0.9pt,yshift=0.8cm]interior.south east) --
        ([xshift=0.9pt,yshift=0.8cm]interior.south west) [rounded corners] -- cycle;
    },
    %===== BANDEAU + ONGLET + TITRE + OMBRE + REHAUT (au-dessus) =======
    overlay={%
      % (two) : noeud de mesure du libelle d'onglet, ancre N-E sur frame.NE
      \node[anchor=north east, minimum height=20pt, inner xsep=5pt, inner ysep=0pt]
            (two) at (frame.north east) {#2\hspace*{.5mm}};
      % --- bandeau colore avec renflement et pli (\path[fill=#2,draw=#2]) ---
      \path[fill=#1, draw=#1]
        ($(frame.north west)+(0ex,-4.5pt)$) [rounded corners=3pt] --
        ($(two.north west)+(-22pt,-4.5pt)$) --
        ($(two.south west)+(-4pt,0pt)$) [sharp corners] --
        (two.south east) [rounded corners] --
        (frame.north east) --
        (frame.north west) [sharp corners] -- cycle;
      % --- titre noir en haut a gauche (noeud three) ---
      \node[text=black, anchor=north west, align=left, minimum height=20pt,
            text height=2ex, inner sep=8pt, inner ysep=3pt, font=\bfseries]
            (three) at ($(frame.north west)+(0,-3pt)$) {\bfdSybTitle};
      % --- libelle blanc dans l'onglet (noeud for) ---
      \node[text=white, anchor=north east, align=center, minimum height=20pt,
            inner sep=8pt, inner ysep=6.5pt, font=\bfseries\footnotesize\sffamily]
            (for) at ($(frame.north east)+(0,1.5pt)$) {#2\hspace*{0.8mm}};
      % --- ombre degradee sous le pli (\foreach) ---
      \foreach \x in {10,20,...,100}{%
        \path[opacity=\x*0.01]
          ($(frame.north west)+(0.4pt,-6.5pt+\x/100)$) [rounded corners=3pt,draw=gray!\x] --
          ($(two.north west)+(-23.3pt+\x/100,-6.5pt+\x/100)$) [rounded corners=3.5pt,draw=gray!\x] --
          ($(two.south west)+(-5.3pt+\x/100,-1.9pt+\x/100)$) --
          ($(two.south east)+(-0.4pt,-1.9pt+\x/100)$);}%
      % --- rehaut blanc (\path[draw=white,line width=1.1pt]) ---
      \path[draw=white,line width=1.1pt]
        ($(frame.north west)+(0.4pt,-5.2pt)$) [rounded corners=3pt] --
        ($(two.north west)+(-22.3pt,-5.2pt)$) [rounded corners=3.5pt] --
        ($(two.south west)+(-4.3pt,-0.6pt)$) --
        ($(two.south east)+(-0.4pt,-0.6pt)$);
    },
  },
  % Alias dedie « histoire » (couleur sepia + onglet « Un peu d'histoire »).
  bfd histoire/.style={bfd syBrisse={histoire}{Un peu d'histoire}},
}

% Environnement Histoire : titre (m), auteur (o, optionnel), corps (+b).
\NewDocumentEnvironment{Histoire}{m o +b}{%
  \def\bfdSybTitle{#1}%
  \IfValueTF{#2}{\def\bfdSybAuthor{#2}}{\def\bfdSybAuthor{}}%
  \begin{tcolorbox}[bfd histoire]%
    \bfdSetColors{histoire}%
    #3%
    \bfdResetColors
  \end{tcolorbox}%
}{}

\endinput

