% =====================================================================
% tcbenumerate — refonte avec auto-niveau d'imbrication (Phase E)
% =====================================================================
% Profondeur courante d'imbrication (0 = hors env, 1/2/3 = niveau).
\@ifundefined{c@bfdEnumDepth}{\newcounter{bfdEnumDepth}}{}
\setcounter{bfdEnumDepth}{0}
% Trois compteurs nommés, un par niveau (max 3 niveaux supportés).
\@ifundefined{c@bfdEnumCntA}{\newcounter{bfdEnumCntA}}{}
\@ifundefined{c@bfdEnumCntB}{\newcounter{bfdEnumCntB}}{}
\@ifundefined{c@bfdEnumCntC}{\newcounter{bfdEnumCntC}}{}
% Indent gauche selon le niveau (configurable depuis le document).
\providecommand{\bfdEnumIndentI}{0em}
\providecommand{\bfdEnumIndentII}{1.5em}
\providecommand{\bfdEnumIndentIII}{3em}

% Compatibilité ascendante : ces noms anciens restent définis afin de ne
% pas casser un document qui les référencerait quelque part. Si bfcours
% les a déjà déclarés (cas du mode override), on les conserve.
\@ifundefined{c@tcbenumcounter}{\newcounter{tcbenumcounter}}{}
\@ifundefined{ifintcbenumerate}{\newif\ifintcbenumerate\intcbenumeratefalse}{}
\@ifundefined{c@savedtcbenumcounter}{\newcounter{savedtcbenumcounter}}{}
\@ifundefined{iftcbenumisalpha}{\newif\iftcbenumisalpha\tcbenumisalphafalse}{}
% Flag interne : mode `tight` détecté pour l'imbrication courante.
% Levé quand \lastkern=1sp au begin du tcbenumerate enfant (cf. sentinelle).
\@ifundefined{ifbfd@enumtight}{\newif\ifbfd@enumtight\bfd@enumtightfalse}{}

% Initialisation par défaut (utilisé si \bfdEnumNum/\bfdEnumLabel sont appelés
% hors d'un tcbenumerate, p.ex. dans un paragraphe d'introduction).
\def\bfdEnumCurCounter{bfdEnumCntA}
\def\bfdEnumCurAuto{arabic}
\def\bfdEnumForcedFormat{auto}

% Sélection du compteur et du format de label selon la profondeur.
%   \bfdEnumCurCounter : nom du compteur du niveau courant
%   \bfdEnumCurAuto    : nom de la macro de formatage (arabic/alph/roman)
\newcommand{\bfdEnumSelect}{%
    \ifcase\value{bfdEnumDepth}%
        \def\bfdEnumCurCounter{bfdEnumCntA}\def\bfdEnumCurAuto{arabic}%
    \or
        \def\bfdEnumCurCounter{bfdEnumCntA}\def\bfdEnumCurAuto{arabic}%
    \or
        \def\bfdEnumCurCounter{bfdEnumCntB}\def\bfdEnumCurAuto{alph}%
    \or
        \def\bfdEnumCurCounter{bfdEnumCntC}\def\bfdEnumCurAuto{roman}%
    \else
        % Au-delà du niveau 3 : on retombe sur le format roman + cnt C
        \def\bfdEnumCurCounter{bfdEnumCntC}\def\bfdEnumCurAuto{roman}%
    \fi
}

% Indent gauche selon la profondeur (utilisé dans la box externe).
\newcommand{\bfdEnumCurIndent}{%
    \ifcase\value{bfdEnumDepth}0em%
    \or\bfdEnumIndentI%
    \or\bfdEnumIndentII%
    \or\bfdEnumIndentIII%
    \else\bfdEnumIndentIII%
    \fi
}

% Macro qui produit le label affiché dans le badge d'un item.
% Tient compte du format forcé (\bfdEnumForcedFormat) ou de \bfdEnumCurAuto.
\newcommand{\bfdEnumPrintLabel}{%
    \ifx\bfdEnumForcedFormat\bfdEnumAutoToken
        % Format auto : on appelle la macro choisie par \bfdEnumSelect
        \csname \bfdEnumCurAuto\endcsname{\bfdEnumCurCounter}%
    \else
        % Format imposé par l'utilisateur (num/alph/Alph/roman/Roman)
        \csname \bfdEnumForcedFormat @counter\endcsname{\bfdEnumCurCounter}%
    \fi
}
% Tokens internes pour la comparaison
\def\bfdEnumAutoToken{auto}
% Aliases num → arabic, et capture des autres formats
\expandafter\let\csname num@counter\endcsname\arabic
\expandafter\let\csname arabic@counter\endcsname\arabic
\expandafter\let\csname alph@counter\endcsname\alph
\expandafter\let\csname Alph@counter\endcsname\Alph
\expandafter\let\csname roman@counter\endcsname\roman
\expandafter\let\csname Roman@counter\endcsname\Roman

% ---------------------------------------------------------------------
% API utilisateur : accès au compteur courant d'un tcbenumerate
% ---------------------------------------------------------------------
% Utilisable dans le contenu d'un \tcbitem (le compteur a déjà été incrémenté
% par `before upper` quand le contenu utilisateur est traité).
%
%   \bfdEnumNum    : valeur numérique brute du compteur du niveau courant
%                    (1, 2, 3, ... — toujours arabe).
%   \bfdEnumLabel  : label formaté selon le format auto/forcé du niveau
%                    courant (1, 2, 3 au L1 ; a, b, c au L2 ; i, ii, iii au L3 ;
%                    ou format imposé via le 3e argument de tcbenumerate).
%   \bfdEnumLevel  : profondeur d'imbrication courante (1, 2, 3, ...).
%
% Accès direct par niveau (utile pour référencer un niveau parent depuis
% un sous-niveau, p.ex. \bfdEnumLabelI dans un L2 donne le label de la
% question principale englobante) :
%   \bfdEnumNumI/II/III      : valeurs numériques par niveau
%   \bfdEnumLabelI/II/III    : labels formatés par niveau
%
% Exemple :
%   \tcbitem Question (réponse à la \bfdEnumLabel)
\newcommand{\bfdEnumNum}{\arabic{\bfdEnumCurCounter}}
\newcommand{\bfdEnumLabel}{\bfdEnumPrintLabel}
\newcommand{\bfdEnumLevel}{\arabic{bfdEnumDepth}}
\newcommand{\bfdEnumNumI}{\arabic{bfdEnumCntA}}
\newcommand{\bfdEnumNumII}{\arabic{bfdEnumCntB}}
\newcommand{\bfdEnumNumIII}{\arabic{bfdEnumCntC}}
\newcommand{\bfdEnumLabelI}{\arabic{bfdEnumCntA}}
\newcommand{\bfdEnumLabelII}{\alph{bfdEnumCntB}}
\newcommand{\bfdEnumLabelIII}{\roman{bfdEnumCntC}}

% tcbenumerate : énumération multi-colonnes avec items en badges stylés.
% Signature :
%   #1 = nombre de colonnes (défaut 1)
%   #2 = valeur de départ   (défaut 1)
%   #3 = format de label    (défaut auto : niv1=num, niv2=alph, niv3=roman ;
%                            valeurs possibles : auto, num, arabic, alph,
%                            Alph, roman, Roman)
\RenewDocumentEnvironment{tcbenumerate}{O{1} O{1} O{auto}}{%
    % 1) Profondeur d'imbrication
    \stepcounter{bfdEnumDepth}%
    \intcbenumeratetrue
    % 2) Sélection compteur + format auto pour ce niveau
    \bfdEnumSelect
    % 3) Format forcé éventuel
    \def\bfdEnumForcedFormat{#3}%
    \ifx\bfdEnumForcedFormat\@empty\def\bfdEnumForcedFormat{auto}\fi
    % 4) Init compteur du niveau courant à (#2 - 1)
    \edef\bfd@enum@start{\number\numexpr#2-1\relax}%
    \setcounter{\bfdEnumCurCounter}{\bfd@enum@start}%
    % Conserver les anciennes variables synchronisées au niveau 1
    \ifnum\value{bfdEnumDepth}=1
        \setcounter{tcbenumcounter}{\bfd@enum@start}%
        \tcbenumisalphafalse
        \def\bfd@tmp@fmt{#3}\def\bfd@tmp@alph{alph}%
        \ifx\bfd@tmp@fmt\bfd@tmp@alph\tcbenumisalphatrue\fi
    \fi
    % 5) Choix du wrapper selon le niveau d'imbrication.
    %    - Niveau 1 : wrapper tcolorbox[blank] (rendu strictement identique
    %      à l'historique, requis pour la conformité pixel-perfect du test
    %      de référence). Pas de problème car le tcbitemize est de niveau 1.
    %    - Niveau >=2 : on remplace le wrapper par un \leftskip + groupe.
    %      tcolorbox+tcbitemize imbriqués au-delà du 2e niveau perdent le
    %      `before upper` des items (les badges disparaissent). \leftskip est
    %      page-break-safe et préserve `before upper` à toute profondeur.
    \ifnum\value{bfdEnumDepth}=1
        \begin{tcolorbox}[blank, width=\textwidth,boxrule=0pt,
            left=\bfdEnumCurIndent,right=0pt,top=0pt,bottom=0pt,halign=left,breakable]%
        \def\bfd@enum@closewrap{\end{tcolorbox}}%
        % Au niveau 1, l'indent est dans la box (`left=`), pas dans le raster.
        \edef\bfd@enum@rasterleft{0pt}%
    \else
        % Détection auto du contexte d'imbrication via la sentinelle \kern1sp
        % posée par le `before upper` du parent (cf. style `raster every box`).
        % \lastkern doit être capturé AVANT toute autre opération sinon il se
        % réinitialise.
        %   - \lastkern = 1sp : imbrication directe (\tcbitem vide + \begin)
        %     → on consomme le kern trailing et on ne touche PAS à \leftskip
        %     ni à \par. Sinon le \par implicite déclenché par \begin{tcbitemize}
        %     refermerait la ligne du badge parent avec le nouveau \leftskip,
        %     décalant visuellement le badge (bug reproduit avec b. shifté).
        %   - \lastkern = 0sp : du texte précède notre \begin → on force \par
        %     pour fermer le paragraphe avec le \leftskip courant (qui est
        %     l'indent du parent, pas celui du raster enfant).
        \edef\bfd@enum@lastk{\the\lastkern}%
        \ifdim\bfd@enum@lastk=1sp\relax
          % cas tight : retire le kern1sp sentinelle, puis force \par avec
          % le \leftskip courant (=0). Le \kern vertical (non-discardable)
          % rapproche visuellement le raster L>=2 du badge parent.
          \unskip
          \par\nobreak
          \kern-2.15em
          \bfd@enumtighttrue
        \else
          % cas avec texte précédent : fermer le paragraphe proprement
          \ifhmode\par\fi
          \bfd@enumtightfalse
        \fi
        % L'indent du raster L>=2 est porté UNIQUEMENT par `raster left skip`
        % de tcbitemize, qui agit sur la géométrie du raster sans toucher au
        % paragraph state du parent. Aucun \leftskip n'est modifié.
        \def\bfd@enum@closewrap{}%
        \edef\bfd@enum@rasterleft{\bfdEnumCurIndent}%
    \fi
    \begin{tcbitemize}[%
        raster columns=#1,
        raster equal height=rows,
        raster column skip=0.5em,
        raster row skip=5pt,
        raster left skip=\bfd@enum@rasterleft,
        breakable,
        raster every box/.style={
            enhanced, breakable, nobeforeafter,
            colbacktitle=\itemBaseColor,
            colback=\currentBackgroundColor,
            boxrule=-1pt,
            colframe=\itemBaseColor,
            fonttitle=\bfseries\color{white},
            arc=5pt, sharp corners=south,
            left=0pt,right=0pt,top=0pt,bottom=0pt,
            valign=top, halign=left,
            toptitle=2pt, bottomtitle=3pt,
            lefttitle=5pt, righttitle=5pt,
            before upper={%
                \stepcounter{\bfdEnumCurCounter}%
                \ifnum\value{bfdEnumDepth}=1\stepcounter{tcbenumcounter}\fi
                \tikz[baseline=(numbox.base)]{\node[
                    inner sep=3pt,
                    font=\large\bfseries,
                    text=white,
                    fill=\itemBaseColor,
                    minimum width=1.5em, minimum height=1.5em,
                    rounded corners=2pt,
                    text centered
                ] (numbox) {\bfdEnumPrintLabel.};}%
                \hspace{3pt}%
                % Sentinelle pour détection du contexte "tight" par un
                % tcbenumerate imbriqué : kern de signature 1sp (invisible)
                % placé juste après le badge du parent. Si l'enfant voit
                % \lastkern=1sp dans son begin code, c'est qu'aucun glyphe
                % n'a été émis entre le badge parent et lui (imbrication
                % directe). Tout caractère ou glue émis par l'utilisateur
                % entre les deux neutralise ce kern (\lastkern devient 0sp).
                % \ignorespaces consomme l'espace source entre \tcbitem et
                % \begin{tcbenumerate} pour préserver la sentinelle.
                \kern1sp\relax
                \ignorespaces
            },
        }%
    ]%
}{%
    \end{tcbitemize}%
    \bfd@enum@closewrap
    % Décrémenter la profondeur et nettoyer si on sort du niveau racine
    \addtocounter{bfdEnumDepth}{-1}%
    \ifnum\value{bfdEnumDepth}=0
        \intcbenumeratefalse
        \setcounter{tcbenumcounter}{0}%
        \setcounter{bfdEnumCntA}{0}%
        \setcounter{bfdEnumCntB}{0}%
        \setcounter{bfdEnumCntC}{0}%
    \fi
    \ignorespacesafterend
}

