% =====================================================================
% Section 1 — Hooks couleurs (factorisation des 10 occurrences dupliquées)
% =====================================================================

% Variante canonique : accent = COL!80!black + tabulars + items
\newcommand{\bfdSetColors}[1]{%
  \CouleurTexteAccent{#1!80!black}%
  \CouleursTabular{#1}{#1}{white}{#1!5}{blue!50!black}%
  \CouleursSecondaryTabular{#1}{#1!30!white}{black}{#1!5}{#1}%
  \couleurItem{#1}%
}

% Variante Theoreme : accent = thm (sans !80!black) + secondaire Salmon/yellow
\newcommand{\bfdSetColorsTheoreme}{%
  \CouleurTexteAccent{thm}%
  \CouleursTabular{thm}{thm}{white}{thm!5}{blue!50!black}%
  \CouleursSecondaryTabular{thm}{Salmon!30!white}{black}{yellow!10!white}{thm}%
  \couleurItem{thm}%
}

% Variante Definition : accent = defi (sans !80!black)
\newcommand{\bfdSetColorsDefinition}{%
  \CouleurTexteAccent{defi}%
  \CouleursTabular{defi}{defi}{white}{defi!5}{blue!50!black}%
  \CouleursSecondaryTabular{defi}{defi!30!white}{black}{defi!5}{defi}%
  \couleurItem{defi}%
}

% Variante "secondaire seule" : sans \couleurItem (utilisée par OldNotation, OldAide)
\newcommand{\bfdSetColorsNoItem}[1]{%
  \CouleurTexteAccent{#1!80!black}%
  \CouleursTabular{#1}{#1}{white}{#1!5}{blue!50!black}%
  \CouleursSecondaryTabular{#1}{#1!30!white}{black}{#1!5}{#1}%
}

% Reset commun à toutes les variantes
\newcommand{\bfdResetColors}{%
  \resetItemBaseColor%
  \ResetCouleursTabular%
  \ResetCouleursSecondaryTabular%
  \ResetCouleurTexteAccent%
}

% Variante reset sans \resetItemBaseColor (pour OldNotation, OldAide)
\newcommand{\bfdResetColorsNoItem}{%
  \ResetCouleursTabular%
  \ResetCouleursSecondaryTabular%
  \ResetCouleurTexteAccent%
}

% =====================================================================
% Section 2 — Stockage du sous-titre courant
% =====================================================================
% Chaque environnement définit \bfdSubTitle avant d'ouvrir la tcolorbox.
% L'overlay teste \ifx\bfdSubTitle\empty pour afficher/masquer le node droit.
%
% PRINCIPE D'USAGE DUAL :
%   1. Via l'environnement nommé : \begin{Theoreme}[Sous-titre]…\end{Theoreme}
%      Le \NewDocumentEnvironment pose \def\bfdSubTitle{Sous-titre}.
%   2. Via le style tcolorbox direct : \begin{tcolorbox}[bfd theoreme, bfd sub=Sous-titre]…\end{tcolorbox}
%      La clé `bfd sub` (Section 3) pose \def\bfdSubTitle{...}.
%
% Reset automatique en fin de box via `after upper` (cf Section 6) pour
% éviter toute fuite entre deux boîtes consécutives.
\newcommand{\bfdSubTitle}{}

% Hook couleurs voie (b) — modifié par la clé `bfd colors=<key>` (cf §3),
% lu et reset par le `before upper` des styles `bfd didactic skin` et
% `bfd exemple`. Vide par défaut → no-op en voie (a).
\providecommand{\bfdColorsHook}{}

% =====================================================================
% Section 3 — Briques tcbset atomiques
% =====================================================================

\tcbset{
  % -------------------------------------------------------------------
  % Clé `bfd sub` : passe un sous-titre en option de la box.
  %   Usage : \begin{tcolorbox}[bfd theoreme, bfd sub={Pythagore}] ...
  % Équivaut à \def\bfdSubTitle{Pythagore} avant la box.
  % -------------------------------------------------------------------
  bfd sub/.code={\def\bfdSubTitle{#1}},
  bfd sub/.default=,
  % -------------------------------------------------------------------
  % Clé `bfd colors=<key>` : pose les hooks couleurs sémantiques en voie (b).
  %   Usage : \tcbitem[bfd methode, bfd colors=meth, bfd sub={...}]
  %   La clé pose un hook (\bfdColorsHook) qui sera exécuté dans le
  %   `before upper` des styles `bfd didactic skin` et `bfd exemple`.
  %   Le hook est reset après exécution pour ne pas polluer la box suivante.
  %   Si non utilisée (voie a), le hook reste vide → no-op.
  %   Variantes :
  %     - bfd colors=<key>   → \bfdSetColors{<key>}
  %     - bfd colors thm     → \bfdSetColorsTheoreme
  %     - bfd colors defi    → \bfdSetColorsDefinition
  %     - bfd colors noitem=<key> → \bfdSetColorsNoItem{<key>}
  % -------------------------------------------------------------------
  bfd colors/.code={\renewcommand*{\bfdColorsHook}{\bfdSetColors{#1}}},
  bfd colors/.default=,
  bfd colors thm/.code={\renewcommand*{\bfdColorsHook}{\bfdSetColorsTheoreme}},
  bfd colors defi/.code={\renewcommand*{\bfdColorsHook}{\bfdSetColorsDefinition}},
  bfd colors noitem/.code={\renewcommand*{\bfdColorsHook}{\bfdSetColorsNoItem{#1}}},
  % -------------------------------------------------------------------
  % Brique « banderolle arc »
  %   #1 = couleur de remplissage (le « ovale » sous le titre)
  %   #2 = couleur du dégradé (le ruban derrière)
  % -------------------------------------------------------------------
  bfd banner arc/.style 2 args={
    boxed title style={frame code={%
      \path[fill=#1]
        ([yshift=-1mm,xshift=-1mm]frame.north west)
        arc[start angle=0,end angle=180,radius=1mm]
        ([yshift=-1mm,xshift=1mm]frame.north east)
        arc[start angle=180,end angle=0,radius=1mm];
      \path[left color=#2,right color=#2]
        ([xshift=-2mm]frame.north west) -- ([xshift=2mm]frame.north east)
        [rounded corners=1mm]-- ([xshift=1mm,yshift=-1mm]frame.north east)
        -- (frame.south east) -- (frame.south west)
        -- ([xshift=-1mm,yshift=-1mm]frame.north west)
        [sharp corners]-- cycle;
    },interior engine=empty,},
  },
  % -------------------------------------------------------------------
  % Brique « équerres L + node sous-titre droit »
  %   #1 = couleur des deux lignes (gauche et bas)
  %   #2 = xshift du node sous-titre (négatif, depuis frame.north east)
  % La largeur de la minipage du sous-titre suit le calcul standard
  % bfcours : \dimexpr(\columnwidth - 4cm - 0.2\columnwidth)\relax
  % -------------------------------------------------------------------
  % Phase G L2 — Variantes graphiques.
  % bfd edge overlay est un alias dynamique (cf macro \bfd@@set@variant).
  % Variantes livrées : lignes (default), minimal, sidebar.
  % Phase H préservée : chaque variante définit overlay first/middle/
  % last/unbroken pour gérer le break de page proprement.
  bfd edge overlay lignes/.style 2 args={
    overlay first={%
      \draw[line width=0.5mm, #1]
        ([xshift=0mm]frame.south west)--([xshift=0mm]frame.north west);
      \ifx\bfdSubTitle\empty\else
        % Node centré dans l'espace latéral disponible entre la banderolle
        % titre (title.east) et le bord droit du frame (frame.east).
        % Varwidth adaptatif : se rétracte si le contenu est court,
        % limité par la formule standard bfcours.
        \node[anchor=center, fill=white, draw=#1, rounded corners]
          at ($(title.east)!0.5!(title.east -| frame.east)$)
          {\begin{varwidth}{\dimexpr 0.4\columnwidth - 1cm\relax}%
            \centering\textbf{\bfdSubTitle}%
          \end{varwidth}};
      \fi%
    },
    overlay middle={%
      \draw[line width=0.5mm, #1]
        ([xshift=0mm]frame.south west)--([xshift=0mm]frame.north west);
    },
    overlay last={%
      \draw[line width=0.5mm, #1]
        ([xshift=0mm,yshift=-0.25mm]frame.south west)--([xshift=0mm]frame.north west);
      \draw[line width=0.5mm, #1]
        ([yshift=0mm]frame.south west)--([yshift=0mm]frame.south east);
    },
    overlay unbroken={%
      \draw[line width=0.5mm, #1]
        ([xshift=0mm,yshift=-0.25mm]frame.south west)--([xshift=0mm]frame.north west);
      \draw[line width=0.5mm, #1]
        ([yshift=0mm]frame.south west)--([yshift=0mm]frame.south east);
      \ifx\bfdSubTitle\empty\else
        % Centré dans l'espace latéral disponible (idem overlay first).
        % Note : overlay unbroken s'applique au cas mono-page (le 99% des
        % envs courts), c'est cette version qui détermine le rendu visible.
        \node[anchor=center, fill=white, draw=#1, rounded corners]
          at ($(title.east)!0.5!(title.east -| frame.east)$)
          {\begin{varwidth}{\dimexpr 0.4\columnwidth - 1cm\relax}%
            \centering\textbf{\bfdSubTitle}%
          \end{varwidth}};
      \fi%
    },
  },
  % --- Variante minimal : un fin trait gauche, pas de sous-titre ---
  % Note : #1 est déjà la couleur nuancée passée par bfd theoreme
  % (typiquement `thm!50`). On l'utilise telle quelle sans la re-nuancer.
  bfd edge overlay minimal/.style 2 args={
    overlay={%
      \draw[line width=0.2mm, #1]
        ([xshift=0mm]frame.south west)--([xshift=0mm]frame.north west);
    },
  },
  % --- Variante sidebar : grosse bande gauche colorée ---
  bfd edge overlay sidebar/.style 2 args={
    overlay first={%
      \fill[#1] (frame.south west) rectangle ([xshift=3mm]frame.north west);
      \ifx\bfdSubTitle\empty\else
        \node[anchor=north east, fill=white, draw=#1, rounded corners]
          at ([xshift=#2]frame.north east)
          {\begin{minipage}{\dimexpr(\columnwidth - 4cm - 0.2\columnwidth)\relax}%
            \centering\textbf{\bfdSubTitle}%
          \end{minipage}};
      \fi%
    },
    overlay middle={%
      \fill[#1] (frame.south west) rectangle ([xshift=3mm]frame.north west);
    },
    overlay last={%
      \fill[#1] (frame.south west) rectangle ([xshift=3mm]frame.north west);
    },
    overlay unbroken={%
      \fill[#1] (frame.south west) rectangle ([xshift=3mm]frame.north west);
      \ifx\bfdSubTitle\empty\else
        \node[anchor=north east, fill=white, draw=#1, rounded corners]
          at ([xshift=#2]frame.north east)
          {\begin{minipage}{\dimexpr(\columnwidth - 4cm - 0.2\columnwidth)\relax}%
            \centering\textbf{\bfdSubTitle}%
          \end{minipage}};
      \fi%
    },
  },
  % L'alias bfd edge overlay/.style 2 args est défini dynamiquement
  % via \bfd@@set@variant (cf section L2). Pas de définition statique ici.
  % --- Variante wide lignes : pour OldExemple, RemarqueOld ---
  bfd edge overlay wide lignes/.style 2 args={
    overlay first={%
      \draw[line width=0.5mm, #1]
        ([xshift=0mm]frame.south west)--([xshift=0mm]frame.north west);
      \ifx\bfdSubTitle\empty\else
        \node[anchor=north east, fill=white, draw=#1, rounded corners]
          at ([xshift=#2]frame.north east)
          {\begin{minipage}{0.5\textwidth}%
            \centering\textbf{\bfdSubTitle}%
          \end{minipage}};
      \fi%
    },
    overlay middle={%
      \draw[line width=0.5mm, #1]
        ([xshift=0mm]frame.south west)--([xshift=0mm]frame.north west);
    },
    overlay last={%
      \draw[line width=0.5mm, #1]
        ([xshift=0mm,yshift=-0.25mm]frame.south west)--([xshift=0mm]frame.north west);
      \draw[line width=0.5mm, #1]
        ([yshift=0mm]frame.south west)--([yshift=0mm]frame.south east);
    },
    overlay unbroken={%
      \draw[line width=0.5mm, #1]
        ([xshift=0mm,yshift=-0.25mm]frame.south west)--([xshift=0mm]frame.north west);
      \draw[line width=0.5mm, #1]
        ([yshift=0mm]frame.south west)--([yshift=0mm]frame.south east);
      \ifx\bfdSubTitle\empty\else
        \node[anchor=north east, fill=white, draw=#1, rounded corners]
          at ([xshift=#2]frame.north east)
          {\begin{minipage}{0.5\textwidth}%
            \centering\textbf{\bfdSubTitle}%
          \end{minipage}};
      \fi%
    },
  },
  bfd edge overlay wide/.style 2 args={bfd edge overlay wide lignes={#1}{#2}},
  % -------------------------------------------------------------------
  % Style composite « didactique-classique »
  %   Squelette commun aux 8 envs principaux (Theoreme, Definition,
  %   Propriete, Demonstration, Methode, Activite, Vocabulaire, Solution
  %   et leurs Old*-variantes).
  % -------------------------------------------------------------------
  bfd didactic base/.style={
    enhanced,
    before skip=2mm, after skip=2mm,
    boxrule=0pt,
    attach boxed title to top left={xshift=1cm,yshift*=1mm-\tcboxedtitleheight},
    varwidth boxed title*=-3cm,
    fonttitle=\bfseries,
    coltitle=white,
    drop shadow,
  },
}

% =====================================================================
% Section 4 — Brique « cracked » (factorisation de l'environnement cracked)
%   L'env cracked d'origine avait déjà une bonne structure (6 args).
%   On le réécrit ici à l'identique pour rester autonome.
% =====================================================================

\tcbset{
  % -------------------------------------------------------------------
  % Brique « cadre déchiré + titre incliné »
  %   #1 = couleur du cadre (random steps)
  %   #2 = couleur du fond du titre incliné
  %   #3 = largeur du titre incliné (text width)
  % La macro \bfdCrackedTitle contient le texte du titre.
  % La macro \bfdSubTitle est testée pour le node minipage optionnel.
  % -------------------------------------------------------------------
  bfd cracked frame/.style n args={3}{
    enhanced,
    frame code={},
    interior code={},
    colback=white,
    drop shadow,
    overlay={%
      % SEED DÉTERMINISTE : un compteur dédié, incrémenté à chaque overlay
      % cracked rencontré dans le document. Garantit que les contours
      % « random steps » sont reproductibles entre deux compilations
      % (sinon TikZ utilise un seed différent à chaque run sous LuaTeX).
      \stepcounter{bfdCrackedSeed}%
      \pgfmathsetseed{\value{bfdCrackedSeed}}%
      \filldraw[
        decoration={random steps, segment length=0.4cm},
        decorate,
        draw=#1,
        ultra thick,
        fill=white
      ] (frame.south west) rectangle (frame.north east);
      % Nouveau seed pour le titre (sinon décoration identique sur deux nodes proches)
      \stepcounter{bfdCrackedSeed}%
      \pgfmathsetseed{\value{bfdCrackedSeed}}%
      \node[
        rotate=10,
        anchor=north west,
        align=center,
        draw=#2, fill=#2,
        decoration={random steps, segment length=0.2cm},
        decorate,
        text=white,
        text width=#3,
        inner ysep=3pt, inner xsep=5pt,
        ultra thick,
        font={\bfseries\fontsize{16pt}{20pt}\selectfont},
      ] at ([xshift=-3mm, yshift=-3mm]frame.north west) {\centering\textbf{\bfdCrackedTitle}};
      \ifx\bfdSubTitle\empty\else
        \node[anchor=north east, fill=white, draw=#1!50, rounded corners]
          at ([xshift=-0.1\columnwidth,yshift=-0.25cm]frame.north east)
          {\begin{minipage}{\dimexpr(\columnwidth - 4cm - 0.2\columnwidth)\relax}%
            \centering\textbf{\bfdSubTitle}%
          \end{minipage}};
      \fi%
    },
    title={},
    attach boxed title to top left={yshift=-6mm, xshift=-1mm},
    boxed title style={interior code={}, frame code={}, center title,},
    title style={\color{white}},
    colframe=#1,
    colback=white,
    fonttitle={\large\textbf},
    left=5mm, right=5mm, top=10mm, bottom=5mm,
    drop fuzzy shadow,
  },
}

% Macro auxiliaire pour stocker le titre incliné du cracked
\newcommand{\bfdCrackedTitle}{}

% Compteur de seed pour la décoration « random steps » du cracked frame.
% Incrémenté à chaque overlay dessiné → contours déterministes entre runs.
\@ifundefined{c@bfdCrackedSeed}{\newcounter{bfdCrackedSeed}}{}
\setcounter{bfdCrackedSeed}{42}

% =====================================================================
% Section 5 — Briques « tikz-corners » (Exemple, ContreExemple)
% =====================================================================

\tcbset{
  % -------------------------------------------------------------------
  % Style « tikz-corners » : coin haut-gauche arrondi, équerres TikZ
  %   #1 = couleur de fond contenu (e.g. gray!2!white, red!2!white)
  %   #2 = couleur du titre (e.g. gray!80!black, red!80!black)
  % -------------------------------------------------------------------
  bfd tikz corners/.style 2 args={
    colback=#1,
    colframe=black,
    fonttitle=\large\bfseries,
    boxrule=0.5mm,
    coltitle=white,
    sharp corners=south,
    rounded corners=northwest,
    attach boxed title to top left={yshift=-4mm, xshift=-2mm},
    boxed title style={
      colback=#2, colframe=#2,
      sharp corners, boxrule=0mm, rounded corners,
    },
    before upper={},
    frame hidden,
  },
  % -------------------------------------------------------------------
  % Overlay des 3 lignes TikZ (verticale sous titre, horizontale droite,
  % équerre bas-droit) + node sous-titre à droite du titre
  %   #1 = couleur des lignes (gray!80!black, red!80!black)
  % -------------------------------------------------------------------
  bfd tikz corners overlay/.style={
    overlay={%
      % Ligne verticale sous le titre
      \draw[#1, line width=1.5pt]
        (frame.north west)++(0.075,-0.2cm) -- ++(0,-2cm);
      % Ligne horizontale à droite du titre
      \draw[#1, line width=1.5pt]
        (title.east) -- ++(3cm,0);
      % Équerre angle bas-droit
      \draw[#1, line width=1.5pt]
        (frame.south east)++(-2cm,0.075cm) -- ++(1.925cm,0) -- ++(0,2cm);
      \ifx\bfdSubTitle\empty\else
        \node[anchor=west, fill=white, draw=#1, rounded corners] at ([xshift=3cm]title.east) {\begin{minipage}{0.5\columnwidth} \centering \textbf{\bfdSubTitle} \end{minipage}};
      \fi%
    },
  },
}

% Anciens styles tcolorbox bfcours (préservés pour compatibilité éventuelle)
\tcbset{
  exempleboxstyle/.style={bfd tikz corners={gray!2!white}{gray!80!black}},
  contreexempleboxstyle/.style={bfd tikz corners={red!2!white}{red!80!black}},
}

% =====================================================================
% Section 6 — Styles tcbset par environnement (interface unifiée)
% =====================================================================
% Chaque environnement bfcours est exposé comme UN style tcbset autonome
% portant le VISUEL pur (banderolle, frame, équerres, titre). Les hooks
% couleurs (\CouleursTabular, \couleurItem, etc.) sont en revanche
% appliqués par le \NewDocumentEnvironment (Section 7), PAS dans le
% style, car `before upper` s'exécute trop tard dans tcolorbox et
% perturbe le rendu pixel-perfect.
%
% USAGE DUAL — chaque style peut être consommé de deux manières :
%
%   (a) Via l'environnement nommé (couleurs sémantiques actives) :
%       \begin{Theoreme}[Sous-titre]
%         Contenu (les tableaux/items utilisent les couleurs sémantiques)
%       \end{Theoreme}
%
%   (b) Via le style tcolorbox direct (visuel pur, sans hooks couleurs) :
%       \begin{tcolorbox}[bfd theoreme, bfd sub={Sous-titre}]
%         Contenu
%       \end{tcolorbox}
%
%   Pour obtenir des hooks couleurs en mode (b), poser explicitement :
%       \bfdSetColorsTheoreme  % AVANT \begin{tcolorbox}
%       \begin{tcolorbox}[bfd theoreme, bfd sub=...] ... \end{tcolorbox}
%       \bfdResetColors
%
% Le reset de \bfdSubTitle est fait APRÈS \end{tcolorbox} dans les
% \NewDocumentEnvironment de la Section 7, jamais dans `after upper`
% (qui s'exécute avant que l'overlay ne lise \bfdSubTitle).

\tcbset{
  % Skin didactique factorisé : application uniforme du couple
  % (cadre + banderolle + bordures + edge overlay + titre liencontent).
  % Paramètres : #1 = clé couleur sémantique (thm, defi, prop, …)
  %              #2 = nom affiché dans la banderolle (« Théorème », …)
  % Les variations (breakable, colback non blanc, banner override) sont
  % ajoutées dans le style spécifique de chaque env via fusion de clés.
  bfd didactic skin/.style 2 args={
    bfd didactic base,
    colback=white, colframe=#1!50,
    bfd banner arc={white!20!#1}{#1!100!black},
    borderline west={0.05mm}{0pt}{#1!80},
    borderline south={0.05mm}{0pt}{#1!80!black},
    bfd edge overlay={#1!50}{-0.1\columnwidth},
    title={\large\liencontent{#2}{\bfdSubTitle}},
    % Bookkeeping HORS du titre varwidth : la cle `code={...}` est
    % evaluee pendant le parsing des options tcolorbox, avant la
    % construction du boxed title. C'est la qu'on enregistre l'entree
    % TOC, le bookmark hyperref et le label, sans que varwidth ne tente
    % de reprocesser ces commandes a effet de bord.
    code={\bfdLiencontentRegister{#2}{\bfdSubTitle}},
    % Hook couleurs voie (b) : exécuté dans le scope du contenu, reset
    % global après exécution. No-op si la clé `bfd colors=<key>` n'a
    % pas été posée (voie a → \bfdColorsHook reste vide).
    before upper={\bfdColorsHook\renewcommand*{\bfdColorsHook}{}},
  },
  % -- Envs didactiques principaux : skin factorisé ------------------
  % Bug historique normalisé (Phase G) : la banderolle Théorème utilisait
  % `red` en dur dans bfcours-environments.sty d'origine. On l'aligne sur
  % la couleur sémantique `thm` pour permettre une palette cohérente.
  bfd theoreme/.style={bfd didactic skin={thm}{Théorème}},
  bfd definition/.style={bfd didactic skin={defi}{Définition}},
  bfd propriete/.style={bfd didactic skin={prop}{Propriété}},
  bfd demonstration/.style={bfd didactic skin={demo}{Démonstration}},
  bfd methode/.style={bfd didactic skin={meth}{Méthode}},
  bfd activite/.style={bfd didactic skin={act}{Activité}, breakable},
  bfd vocabulaire/.style={bfd didactic skin={nota}{Vocabulaire}},
  % -- Solution : skin {green}{Solution} + banner avec accent black ----
  %    (variation par rapport au pattern par défaut : la banderolle
  %    Solution est en black!20!green et non white!20!green pour mieux
  %    contraster sur fond vert).
  bfd solution/.style={
    bfd didactic skin={green}{Solution},
    bfd banner arc={black!20!green}{green!80!black},
  },
  % -- RemarqueOld : skin green avec colback teinté + edge wide + titre sans lien
  bfd remarque old/.style={
    bfd didactic skin={green}{Remarque},
    colback=green!2!white,
    bfd banner arc={black!20!green}{green!80!black},
    bfd edge overlay wide={green!50}{-4cm},
    title={\large{Remarque}},
  },
  % -- OldExemple : skin ex + colback teinté + edge wide + suffixe (s) -
  bfd old exemple/.style={
    bfd didactic skin={ex}{Exemple},
    colback=ex!2!white,
    bfd edge overlay wide={ex!50}{-4cm},
    title={\large{Exemple}\scriptsize{(s)}},
  },
  % -- OldNotation : skin nota + colback teinté + titre sans lien ------
  bfd old notation/.style={
    bfd didactic skin={nota}{Notation},
    colback=nota!2!white,
    title={\large{Notation}},
  },
  % -- OldAide : skin nota + titre sans lien ---------------------------
  bfd old aide/.style={
    bfd didactic skin={nota}{Aide},
    title={\large{Aide}},
  },
  % -- Exemple (nouveau, tikz-corners + 3 lignes + sous-titre minipage) -
  % Style symétrique aux autres `bfd <env>` pour autoriser la voie (b) :
  %   \begin{tcolorbox}[bfd exemple, bfd sub={Application}] ... \end{tcolorbox}
  %   \tcbitem[bfd exemple, bfd sub={Application}] ...   (dans MultiColonnes)
  % NB : duplique le visuel de \bfdDeclareEnv{Exemple} (Section 9, l. 1540-
  % 1560). L'env Exemple n'est PAS refactoré pour préserver le pixel-perfect
  % de la voie (a).
  bfd exemple/.style={
    exempleboxstyle,
    % Hook couleurs voie (b) : pose la palette `ex` par défaut + accent
    % textuel nota!80!black hérité de l'env Exemple original. L'utilisateur
    % peut override via `bfd colors=<key>` (rare, mais possible).
    before upper={%
      \bfdColorsHook\renewcommand*{\bfdColorsHook}{}%
      \bfdSetColors{ex}%
      \CouleurTexteAccent{nota!80!black}%
      \vspace{0.5cm}%
    },
    title={\liencontent{Exemple(s)}{\bfdSubTitle}},
    code={\bfdLiencontentRegister{Exemple(s)}{\bfdSubTitle}},
    overlay={%
      \draw[gray!80!black, line width=1.5pt]
        (frame.north west)++(0.075,-0.2cm) -- ++(0,-2cm);
      \draw[gray!80!black, line width=1.5pt]
        (title.east) -- ++(3cm,0);
      \draw[gray!80!black, line width=1.5pt]
        (frame.south east)++(-2cm,0.075cm) -- ++(1.925cm,0) -- ++(0,2cm);
      \ifx\bfdSubTitle\empty\else
        % Node placé sur le trait qui sort à droite de la banderolle
        % « Exemple(s) » (le trait part de title.east et va à xshift=3cm).
        % Ancrage west à title.east + petit xshift : le node démarre
        % juste après le titre, sur le trait. Varwidth adaptatif.
        \node[anchor=west, fill=white, draw=gray!80!black, rounded corners]
          at ([xshift=0.8cm]title.east)
          {\begin{varwidth}{\dimexpr(\columnwidth - 4cm - 0.2\columnwidth)\relax}%
            \centering\textbf{\bfdSubTitle}%
          \end{varwidth}};
      \fi
    },
  },
  % -- PunitionBox (recopié de bfcours-environments.sty l. 1385-1416) -
  bfd punition/.style={
    bfd didactic base,
    colback=defi!2!white, colframe=defi!50,
    bfd banner arc={white!20!defi}{defi!100!black},
    borderline west={0.05mm}{0pt}{defi!80},
    borderline south={0.05mm}{0pt}{defi!80!black},
    overlay={%
      \draw[line width=0.5mm, defi!50]
        ([xshift=0mm,yshift=-0.25mm]frame.south west)--([xshift=0mm]frame.north west);
      \draw[line width=0.5mm, defi!50]
        ([yshift=0mm]frame.south west)--([yshift=0mm]frame.south east);
      \node[anchor=north east, fill=white, draw=defi!50, rounded corners]
        at (frame.north east)
        {\begin{minipage}{0.7\textwidth}%
          \textbf{Prénom : }\masquer{Nom et prénom de l'élève puni \hfill \phantom{a}}%
          \textbf{Classe : }\masquer{Classe \ldots\ldots}%
        \end{minipage}};
    },
    title={\large{Punition}},
  },
  % -- boiteFigure (recopié de bfcours-environments.sty l. 1514-1542) -
  bfd figlabel/.code={\def\bfdFigLabel{#1}},
  bfd figlabel/.default=,
  bfd boite figure/.style={
    enhanced,
    colback=white, colframe=black!50,
    arc=2mm,
    fontupper=\normalsize,
    halign=center, valign=center,
    boxsep=5pt,
    left=2pt, right=2pt, top=7mm, bottom=2pt,
    overlay={%
      \node[
        fill=black, text=white,
        font=\scriptsize\bfseries,
        anchor=north west,
        inner sep=3pt, outer sep=0pt,
        minimum height=5mm,
        rectangle,
      ] at ([xshift=0mm, yshift=0mm]frame.north west) {\bfdFigLabel};
    },
  },
}
\newcommand{\bfdFigLabel}{}

% =====================================================================
% Section 7 — Déclarations des environnements didactiques
% =====================================================================
% Chaque \NewDocumentEnvironment :
%   1. Pose \bfdSubTitle = sous-titre passé en option
%   2. Applique les hooks couleurs AVANT \begin{tcolorbox}
%   3. Le contenu utilise ces couleurs sémantiques (tableaux, items)
%   4. Reset les hooks couleurs APRÈS \end{tcolorbox}
%   5. Reset \bfdSubTitle APRÈS \end{tcolorbox} (et non dans `after upper`
%      qui s'exécuterait avant que l'overlay ne lise \bfdSubTitle).

% ---- Théorème ------------------------------------------------------
\bfdNewSemanticEnv{Theoreme}{bfd theoreme}{\bfdSetColorsTheoreme}

% Alias \begin{Theo} → \begin{Theoreme}
\bfdDeclareEnv{Theo}{O{} +b}{\begin{Theoreme}[#1]#2}{\end{Theoreme}}

% ---- TheoA (variante paramétrable) ---------------------------------
% Conservée à l'identique car prend un argument couleur dynamique.
\bfdDeclareTcb{TheoA}[2][thm]{enhanced,
  before skip=2mm,after skip=2mm,
  colback=#1!2!white,colframe=#1!50,boxrule=0.2mm,
  attach boxed title to top left={xshift=1cm,yshift*=1mm-\tcboxedtitleheight},
  varwidth boxed title*=-3cm,
  boxed title style={frame code={%
    \path[fill=tcbcolback!30!#1]
      ([yshift=-1mm,xshift=-1mm]frame.north west)
      arc[start angle=0,end angle=180,radius=1mm]
      ([yshift=-1mm,xshift=1mm]frame.north east)
      arc[start angle=180,end angle=0,radius=1mm];
    \path[left color=tcbcolback!60!#1,right color=tcbcolback!60!#1,
          middle color=tcbcolback!80!#1]
      ([xshift=-2mm]frame.north west) -- ([xshift=2mm]frame.north east)
      [rounded corners=1mm]-- ([xshift=1mm,yshift=-1mm]frame.north east)
      -- (frame.south east) -- (frame.south west)
      -- ([xshift=-1mm,yshift=-1mm]frame.north west)
      [sharp corners]-- cycle;
  },interior engine=empty,},
  fonttitle=\bfseries,
  title={\Large{#2}},
  coltitle=#1!80!black!,
}

% ---- Envs sémantiques factorisés via \bfdNewSemanticEnv ------------
% Pattern commun : \def\bfdSubTitle{#1} + tcolorbox[style] + hook couleurs
% + contenu + reset couleurs. Voir helper en haut du fichier.
\bfdNewSemanticEnv{Definition}{bfd definition}{\bfdSetColorsDefinition}
\bfdNewSemanticEnv{Propriete}{bfd propriete}{\bfdSetColors{prop}}
\bfdNewSemanticEnv{Demonstration}{bfd demonstration}{\bfdSetColors{demo}}
\bfdNewSemanticEnv{Methode}{bfd methode}{\bfdSetColors{meth}}
\bfdNewSemanticEnv{Activite}{bfd activite}{\bfdSetColors{act}}
