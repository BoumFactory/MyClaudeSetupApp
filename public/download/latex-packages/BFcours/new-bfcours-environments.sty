% --- Bookkeeping HORS titre + affichage dans le titre ------------------
% Probleme historique : les titres tcolorbox utilisant `varwidth boxed
% title*=...` passent leur contenu dans le package `varwidth`, qui le
% reprocess pour mesurer la largeur. Si le titre contient des commandes
% a effets de bord/fragiles (\stepcounter, \phantomsection, \hypertarget,
% \addcontentsline, \label), varwidth echoue avec "Failed to reprocess
% entire contents" et hyperref emet "Missing character ... nullfont".
%
% Solution : separer bookkeeping et affichage.
%   * \bfdLiencontentRegister{cat}{titre} : execute UNIQUEMENT le
%     bookkeeping (TOC, bookmark hyperref, label). A appeler AVANT
%     \begin{tcolorbox} (typiquement via la cle `code={...}` du style
%     tcbset de la box), donc HORS du contexte varwidth.
%   * \liencontent{cat}{titre} : ne fait plus QUE l'affichage (\textbf).
%     Reste utilisable dans `title={...}` sans declencher varwidth.
%
% \phantomsection est requis avant \addcontentsline pour eviter le
% warning "anchor of a bookmark and its parent's must not be the same"
% quand l'environnement suit immediatement un \section.
%
% \texorpdfstring : la TOC affichee garde la couleur, les bookmarks PDF
% recoivent juste le texte (sinon "blue!90!black" apparait dans l'outline).
\newcommand{\bfdLiencontentRegister}[2]{%
  \stepcounter{contentcounter}%
  \phantomsection
  \hypertarget{subsec:\thecontentcounter}{}%
  \addcontentsline{toc}{subsection}{\protect\numberline{}\textbf{#1} - {\texorpdfstring{\textcolor{blue!90!black}{#2}}{#2}}}%
  \label{subsec:#1\thecontentcounter}%
}
\newcommand{\bfdLiensecretcontentRegister}[2]{%
  \stepcounter{contentcounter}%
  \phantomsection
  \hypertarget{subsec:\thecontentcounter}{}%
  \addcontentsline{toc}{subsubsection}{\protect\numberline{}\textbf{#1} - {\texorpdfstring{\textcolor{blue!90!black}{#2}}{#2}}}%
  \label{subsec:#1\thecontentcounter}%
}

% \liencontent et \liensecretcontent : juste l'affichage. Le bookkeeping
% est fait separement par \bfdLiencontentRegister dans le code/style de
% chaque environnement.
\newcommand{\liencontent}[2]{\textbf{#1}}
\newcommand{\liensecretcontent}[2]{}

