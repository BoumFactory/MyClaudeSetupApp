            |>{\centering\arraybackslash}p{0.9cm}}
          \hline
          \rule[0pt]{0pt}{8pt}\cellcolor{red!10!white}\mi
            &\cellcolor{orange!10!white}\mf
            &\cellcolor{yellow!10!white}\ms
            &\cellcolor{green!10!white}\tbm \\
          \hline
